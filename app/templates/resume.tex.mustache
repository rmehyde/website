% setup document class and margins
\documentclass[11pt]{article}
\usepackage[margin=0.75in]{geometry}

% alignment is declared per-section (no global package). bullets are ragged via the
% itemize setup below; flowing sections wrap their body in {\raggedright ...\par} or
% {\justify ...\par}. \raggedright is built in; define its justified counterpart:
\newcommand{\justify}{\leftskip=0pt \rightskip=0pt \parfillskip=0pt plus 1fil\relax \tolerance=9999 \emergencystretch=3em\relax}

% hyphenation: discourage breaks slightly, and never hyphenate Capitalized words,
% which covers CamelCase brand names (PyTorch, ClickHouse, Kubernetes, ...).
% Add exact exceptions to \hyphenation{} for any that slip through.
\hyphenpenalty=200
\uchyph=0
\hyphenation{PyTorch TensorFlow ClickHouse Kubernetes SwiftLaTeX Buildkite}
%\usepackage{parskip}

% CharisSIL font
\usepackage{CharisSIL}

% tables for header
\usepackage{tabularx, array, makecell, enumitem}

% section heading style
\usepackage{titlesec}
\titlespacing*{\section}{0pt}{1.5ex}{0.5ex}
\titleformat{\section}{\large\bfseries}{}{0pt}{}

% lists
\setlist[itemize,2]{leftmargin=2.5em}
% make bullets bigger?
% \pagestyle{empty}
\setlist[itemize]{noitemsep, topsep=0pt, leftmargin=*,
% label={\LARGE\textbullet}
label={\tb},
before=\raggedright  % bullets always ragged; headers stay justified so their \hfill works
}

% links
\usepackage[dvipsnames]{xcolor}
\definecolor{Cobalt}{HTML}{0047AB}
\usepackage[hidelinks]{hyperref}
\hypersetup{
    colorlinks=true,
    pdfhighlight=/N,
    linkcolor=Cobalt,
    urlcolor=Cobalt,
    citecolor=Cobalt,
}


% soul for underlining
% \usepackage{soul}
% \setul{0.3ex}{0.15ex}
% \setulcolor{Cobalt}

% ulem for underlining
\usepackage[normalem]{ulem}
\renewcommand\ULthickness{0.15ex}
\renewcommand\ULdepth{.3ex}


% uhref is an underlined link
\newcommand*\uhref[2]{\href{#1}{\uline{#2}}}
% blkuhref is a black underlined link
\newcommand{\blkuhref}[2]{%
    \begingroup
    \hypersetup{allcolors=black}% temporarily override every link color
    \uhref{#1}{#2}%
    \endgroup
}

% special glyphs since I don't like the ones in the text font
\newfontfamily\glyphfont{TeX Gyre Pagella}
\newcommand{\rightarr}{{\glyphfont →}}
\newcommand{\tb}{{\glyphfont\large\raisebox{-0.07ex}{•}}}
% separator between inline items: breakable space, bullet, then a non-breaking space, so a
% line can break only BEFORE the bullet — the bullet always rolls to the next line with its item
\newcommand{\bulletspace}{\space\tb~}
% leading bullet for the first item: no leading space, so it sits flush whether it starts a
% fresh paragraph (Projects) or follows \noindent (OSS) — fixes the inconsistent first-item gap
\newcommand{\leadbullet}{\tb~}


% headers and footers
\usepackage{fancyhdr}
\fancyhf{}
\cfoot{\fontsize{7.5}{8}\selectfont This document was built from one of over fifty million input configurations to my dynamic resume generator. Tune it yourself at \blkuhref{http://rmehyde.com/resume}{rmehyde.com/resume}.}
\pagestyle{fancy}

